{
    "name": "@kuindji/memory-domain",
    "version": "0.0.6",
    "type": "module",
    "description": "Domain-driven memory engine with graph storage, embeddings, and semantic search",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/kuindji/memory-domain.git"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "bin": {
        "memory-domain": "dist/cli/cli.js",
        "memory-domain-tui": "dist/tui/tui.js",
        "memory-domain-download-model": "dist/bin/download-model.js",
        "memory-domain-download-mlx-model": "dist/bin/download-mlx-model.js",
        "memory-domain-download-gguf-model": "dist/bin/download-gguf-model.js"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "rm -rf dist && tsc -p tsconfig.build.json && node scripts/copy-assets.js",
        "prepublishOnly": "bun run build",
        "test": "bun test",
        "test:integration": "bun test --timeout 180000 --test-root ./tests-integration",
        "typecheck": "tsc --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "memory-domain": "bun run src/cli/cli.ts",
        "tui": "bun run src/tui/tui.ts",
        "publish": "npm publish --access public"
    },
    "dependencies": {
        "@anthropic-ai/bedrock-sdk": "^0.28.1",
        "@aws-sdk/client-s3": "^3.1023.0",
        "@aws-sdk/credential-providers": "^3.1023.0",
        "@clack/prompts": "^1.2.0",
        "@electric-sql/pglite": "^0.4.4",
        "@huggingface/transformers": "^4.1.0",
        "jiti": "^2.6.1",
        "js-tiktoken": "^1.0.21",
        "onnxruntime-node": "^1.24.1",
        "postgres": "^3.4.9",
        "tar": "^7.5.13"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^22.0.0",
        "@types/tar": "^7.0.87",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.1",
        "typescript": "^5",
        "typescript-eslint": "^8.57.2"
    }
}
