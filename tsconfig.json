{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleDetection": "force",
        "moduleResolution": "NodeNext",
        "lib": ["ES2022"],
        "strict": true,
        "skipLibCheck": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "noEmit": true
    },
    "include": [
        "src/index.ts",
        "src/config-loader.ts",
        "src/core/**/*.ts",
        "src/adapters/pg/**/*.ts",
        "src/adapters/connection/**/*.ts",
        "src/adapters/llm/**/*.ts",
        "src/adapters/bge-m3-embedding.ts",
        "src/adapters/cached-embedding.ts",
        "src/adapters/onnx-embedding.ts",
        "src/adapters/wordpiece-tokenizer.ts",
        "src/bin/**/*.ts",
        "src/cli/**/*.ts",
        "src/serve/**/*.ts",
        "src/tui/**/*.ts",
        "src/domains/log-domain.ts",
        "src/domains/topic/**/*.ts",
        "src/plugins/topic-linking.ts",
        "tests/pg-adapters.test.ts",
        "tests/schema-registry-pg.test.ts",
        "tests/graph-store-pg.test.ts",
        "tests/search-engine-pg.test.ts",
        "tests/engine-pg.test.ts",
        "eslint.config.ts",
        "memory-domain.config.ts"
    ]
}
